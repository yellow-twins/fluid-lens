{
    "name": "yellow-twins/fluid-lens",
    "description": "Static analyzer for Fluid templates: finds duplicated markup that should become Partials, plus accessibility and best-practice sniffs.",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "keywords": ["typo3", "fluid", "static-analysis", "linter", "partials", "accessibility", "wcag", "dry"],
    "authors": [
        {
            "name": "Ramon Herrmann",
            "email": "ramon@yellow-twins.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "ext-dom": "*",
        "ext-json": "*",
        "masterminds/html5": "^2.9",
        "symfony/console": "^6.4 || ^7.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.11",
        "phpunit/phpunit": "^10.5",
        "psalm/plugin-phpunit": "^0.19",
        "squizlabs/php_codesniffer": "^3.10",
        "vimeo/psalm": "^5.24"
    },
    "autoload": {
        "psr-4": {
            "YellowTwins\\FluidLens\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "YellowTwins\\FluidLens\\Tests\\": "tests/"
        }
    },
    "bin": ["bin/fluid-lens"],
    "scripts": {
        "analyze": "@php bin/fluid-lens analyze",
        "similar": "@php bin/fluid-lens similar",
        "lint": "@php bin/fluid-lens lint",
        "cs": "phpcs",
        "cs:fix": "phpcbf",
        "stan": "phpstan analyse",
        "psalm": "psalm",
        "test": "phpunit",
        "qa": ["@cs", "@stan", "@psalm", "@test"]
    },
    "config": {
        "sort-packages": true
    }
}
